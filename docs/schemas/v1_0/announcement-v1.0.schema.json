    "CvTermKeyValue": {
      "properties": {
        "key": {
          "$ref": "#/$defs/CvTerm",
          "title": "Key"
        },
        "values": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/QuantitativeValue"
              },
              "type": "array"
            },
            {
              "items": {
                "$ref": "#/$defs/CvTerm"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
