          "type": "string"
        },
        "accession": {
          "default": "",
          "description": "Accession number of CV term in compact URI format.",
          "title": "Accession",
          "type": "string"
        },
        "name": {
          "default": "",
          "description": "Label of CV term.",
          "title": "Name",
          "type": "string"
        }
      },
      "title": "CvTermValue",
      "type": "object"
    },
    "QuantitativeValue": {
      "properties": {
        "value": {
