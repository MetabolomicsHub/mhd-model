    "AnnouncementProtocol": {
      "description": "A protocol is a defined and standardized procedure followed\nto collect, prepare, or analyze biological samples.",
      "properties": {
        "name": {
          "description": "Name or title of the protocol.",
          "title": "Name",
          "type": "string"
        },
        "protocol_type": {
          "$ref": "#/$defs/CvTerm",
          "description": "Type of protocol specified as a Controlled Vocabulary (CV) term.",
          "title": "Protocol Type"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Detailed description of the experimental protocol.",
          "title": "Description"
        },
        "protocol_parameters": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/CvTermKeyValue"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of protocol parameters specified as key-value CV pairs.",
          "title": "Protocol Parameters"
        },
        "relates_assay_names": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of assay names that utilize this protocol.",
          "title": "Relates Assay Names"
        }
      },
      "required": [
        "name",
        "protocol_type"
      ],
      "title": "AnnouncementProtocol",
      "type": "object"
    },
