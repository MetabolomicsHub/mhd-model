{
  "$defs": {
    "AnnouncementContact": {
      "description": "A contact person associated with the dataset.\nThis can be a submitter, author, or a principal investigator.",
      "properties": {
        "full_name": {
          "anyOf": [
            {
              "minLength": 5,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Full name of the contact person.",
          "title": "Full Name"
        },
        "email_list": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of contact email addresses.",
          "title": "Email List"
        },
        "orcid": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ORCID digital identifier of the contact person.",
          "title": "ORCID"
        },
        "affiliation_list": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of institutional affiliations for the contact.",
          "title": "Affiliation List"
        }
      },
      "title": "AnnouncementContact",
      "type": "object"
    },
    "AnnouncementDerivedDataFile": {
